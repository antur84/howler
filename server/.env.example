# Google OAuth client ID (required — must match the one used in the React frontend)
GOOGLE_CLIENT_ID=

# JWT secret for signing session tokens (required in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Server port
PORT=8080

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Cookie settings
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Supabase (required)
SUPABASE_URL=
SUPABASE_KEY=
